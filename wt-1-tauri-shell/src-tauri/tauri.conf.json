{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YTB",
  "version": "0.1.0",
  "identifier": "com.afstudy20.ytb",
  "build": {
    "beforeDevCommand": "cd ../wt-2-ui && pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd ../wt-2-ui && pnpm build",
    "frontendDist": "../../wt-2-ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "YTB",
        "width": 1100,
        "height": 760,
        "minWidth": 360,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "android": {
      "minSdkVersion": 26
    }
  }
}
